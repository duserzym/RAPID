Public Sub cmdStartRamp_Click()

    Dim Verbose As Boolean
    Dim ClippingTest As Boolean
        
    Set UpWave = Nothing
    Set DownWave = Nothing
    Set MonitorWave = Nothing
    
    Dim AF_Data() As Double
    Dim SineFit_Data() As Double
    
    Dim RampMode As Long
    
    Dim RampAgain As Boolean
    Dim ReRampCounter As Long
    
    Dim FolderName As String
    Dim CurTime
    
    If WaveForms Is Nothing Or WaveForms.Count = 0 Then
    
        'CRAP!
        MsgBox "Bad Ramp Wave info!" & vbNewLine & _
                "Garbage values must have been dumped into the Ramp Wave object." & _
                vbNewLine & "Code will end right now!"
        
        End
    
    End If
    
    Set MonitorWave = WaveForms("AFMONITOR")
    Set UpWave = WaveForms("AFRAMPUP")
    Set DownWave = WaveForms("AFRAMPDOWN")
    
    If val(txtRampPeakDuration) < 0 Then
    
        'Reset bad peak hold time to zero seconds
        txtRampPeakDuration = "0"
        
    End If
    
    With UpWave
    
        .Duration = val(txtRampUpDuration)
        .IORate = val(txtRampRate)
        .TimeStep = 1 / .IORate

        .Range.MaxValue = 10
        .Range.MinValue = -10
        .PeakVoltage = val(txtRampPeakVoltage)
        
        If .PeakVoltage > .Range.MaxValue Then
        
            .PeakVoltage = .Range.MaxValue
            txtRampPeakVoltage = Trim(Str(.PeakVoltage))
            
        End If
        
    End With
    
    With DownWave
    
        .Duration = val(txtRampDownDuration)
        .IORate = UpWave.IORate
        .TimeStep = UpWave.TimeStep
        
        .IOOptions = UpWave.IOOptions
        
        Set .Range = UpWave.Range
        .PeakVoltage = UpWave.PeakVoltage
        
        If .PeakVoltage > .Range.MaxValue Then
        
            .PeakVoltage = .Range.MaxValue
            txtRampPeakVoltage.text = Trim(Str(.PeakVoltage))
            
        End If
        
    End With
    
    With MonitorWave
        
        .Duration = (UpWave.Duration + DownWave.Duration) + val(txtRampPeakDuration.text) + 100
    
        'Record the sine freq that the user has selected on the
        'main page as the sine freq that the monitor is trying to match
        .SineFreqMin = val(txtFreq)
        .SineFreqMax = .SineFreqMin
        
        'Now see if 100 pts per period resolution is below the max analog
        'in rate for the board associated with this wave
        .IORate = UpWave.IORate
        
        .PeakVoltage = val(txtMonitorTrigVolt)
        .Range.MaxValue = 10
        .Range.MinValue = -10
        
        If .PeakVoltage > .Range.MaxValue Then
        
            .PeakVoltage = .Range.MaxValue
            txtMonitorTrigVolt.text = Trim(Str(.PeakVoltage))
            
        End If
        
    End With
    
    'Now check to make sure we aren't bumping into the max voltage range for the
    'selected coil
    If optCoil(0).Value = True Then
    
        'Check to see if we're set above the max allowed monitor voltage
        If MonitorWave.PeakVoltage > AxialMaxMonVoltage Then
        
            MonitorWave.PeakVoltage = AxialMaxMonVoltage
                   
        End If
    
        'Check to see if we're set above the max allowed ramp voltage
        If UpWave.PeakVoltage > AxialMaxRampVoltage Then
        
            UpWave.PeakVoltage = AxialMaxRampVoltage
                   
        End If
    
    ElseIf optCoil(1).Value = True Then
    
        'Check to see if we're set above the max allowed monitor voltage
        If MonitorWave.PeakVoltage > TransMaxMonVoltage Then
        
            MonitorWave.PeakVoltage = TransMaxMonVoltage
            
        End If
    
        'Check to see if we're set above the max allowed ramp voltage
        If UpWave.PeakVoltage > TransMaxRampVoltage Then
        
            UpWave.PeakVoltage = TransMaxRampVoltage
            
        End If
    
    Else
    
        'No Coil selected
        'Prompt user
        MsgBox "No AF coil selected.  Please select a coil.", , _
               "No Coil Selected"
               
    End If
    
    'Now check to see if user has clicked the Verbose? checkbox
    If checkVerbose = Checked Then
    
        RampMode = 2
        Verbose = True
        
    Else
    
        RampMode = 1
        
    End If
    
    'Now see if this is an unmonitored ramp cycle for a clipping test
    If checkClippingTest.Value = Checked Then
    
        RampMode = 3
        ClippingTest = True
        
    End If

'---------------------------------------------'
'---------------------------------------------'
'   New Code mod
'   April 13, 2010
'   Isaac Hilburn
'
'   New Function call to do the ramp using
'   the ADWIN board
'---------------------------------------------'

    'Set RampAgain = False as default
    RampAgain = False
    
    'Initialize Re-ramp counter to zero
    ReRampCounter = 0
    
    Do
    
        'Do the AF Ramp cycle
        DoRampADWIN UpWave, _
                    DownWave, _
                    MonitorWave, _
                    AF_Data, _
                    val(txtRampPeakDuration), _
                    RampMode
                                        
        'Is this a clipping test or a monitored ramp?
        If RampMode < 3 And MonitorWave.CurrentVoltage < (MonitorWave.PeakVoltage - NoiseLevel) Then
        
            'This is a monitored ramp, if the target monitor peak voltage was not reached
            'need to ramp again with a higher ramp voltage
            
            'Increase the Ramp (UpWave) peak voltage by the ratio of the highest reached
            'monitor voltage and the desired monitor voltage * 1.5
            '1st - store old Ramp peak voltage
            TempD = UpWave.PeakVoltage
            
            'Now set new voltage
            UpWave.PeakVoltage = TempD * _
                                 (MonitorWave.PeakVoltage / MonitorWave.CurrentVoltage) * _
                                 1.5
                                 
            'Now write the new peak voltage to the form window
            Me.txtRampPeakVoltage = Format(UpWave.PeakVoltage, "0.0##")
                                 
            'Set RampAgain = True
            RampAgain = True
            
            'Increment re-ramp counter
            ReRampCounter = ReRampCounter + 1
                                 
        Else
        
            'Otherwise, don't ramp again
            RampAgain = False
            
        End If
            
        'Check to make sure this new voltage does not exceed the maximum allowed Ramp Voltage
        If optCoil(0).Value = True Then
        
            TempD = AxialMaxRampVoltage
            
        Else
        
            TempD = TransMaxRampVoltage
            
        End If
        
        If UpWave.PeakVoltage > TempD And ReRampCounter > -1 Then
        
            'Set Peak Ramp Voltage to the max allowed for this coil
            UpWave.PeakVoltage = TempD
        
            'Set re-ramp counter to -2
            ReRampCounter = -2
        
        ElseIf UpWave.PeakVoltage > TempD And ReRampCounter <= -1 Then
        
            'Set RampAgain = False, max voltage ramp has already been attempted
            RampAgain = False
            
        End If
        
        'If Re-ramp counter gets above system threshold, throw an error
        If ReRampCounter > ReRampThreshold Then
        
            Err.Raise 616, _
                      "AF Ramp", _
                      "Number of attempted ramps exceeds system threshold limit." & _
                      vbNewLine & vbNewLine & _
                      "Parameters:" & vbNewLine & _
                      vbTab & "Peak Field = " & Trim(Me.txtPeakField) & _
                      Trim(Me.cmbFieldUnits.ItemData(cmbFieldUnits.ListIndex)) & _
                      vbNewLine & vbTab & "Mon. Peak Volt. = " & Trim(Me.txtMonitorTrigVolt) & _
                      " V" & vbNewLine & vbTab & _
                      "Ramp Peak Volt. = " & Trim(Me.txtRampPeakVoltage) & " V" & _
                      vbNewLine & vbTab & "Number of Ramp Attempts = " & _
                      Trim(Str(ReRampCounter)) & _
                      vbNewLine & vbTab & "Max Allowed = " & Trim(Str(ReRampThreshold))
        
            Exit Sub
            
        End If
        
    Loop Until RampAgain = False
                
    'Now need to analyse the resulting sine fit data, if
    'user has selected Verbose or ClippingTest ramp modes
    If Verbose = True Or ClippingTest = True Then
    
        'Do sine fits on the monitor input data
        DoSineFitAnalysis AF_Data, _
                          SineFit_Data, _
                          MonitorWave, _
                          UpWave, _
                          DownWave, _
                          500
        
        'Get the current time
        CurTime = Now
        
        'Set the Local Data folder name
        'Check the Ramp Mode
        If ClippingTest = True Then
        
            FolderName = CoilString & " Clip " & Trim(Str(UpWave.PeakVoltage)) & "V "
            
        Else
        
            FolderName = CoilString & " Ramp " & Trim(Str(MonitorWave.PeakVoltage)) & "V "
            
        End If
        
        FolderName = FolderName & " - " & Format(CurTime, "MM-DD-YY, HH MM SS") & "/"

                 
        'Now Call the Ramp data save function
        frmFileSave.MultiRampFileSave_ADWIN AF_Data, _
                                            UpWave.TimeStep, _
                                            65000, _
                                            FolderName, _
                                            CurTime, _
                                            SineFit_Data, _
                                            False, _
                                            True, _
                                            CLng(MonitorWave.PtsPerPeriod) + 1
                                            
    End If
                
'---------------------------------------------'
    
End Sub

