Private Sub Form_Load()

    'In final version of this code added to the VB Paleomag program
    'These initialization functions will be called
    'In the login phase of the program and will pull their
    'Values from the paleomag.ini file

    'Set the AF System to ADWIN
    AFSystem = "ADWIN"
    
    'Set the ADWIN Bin Folder Path
    ADWIN.BinFolderPath = "C:\Documents and Settings\lab\Desktop\" & _
                          "Test MCC Board 11-16-2009\Test MCC Board\ADwin\"
   
    'Set Interval at which Timer operates to 1 micro-s
    timeBeginPeriod 1
    
    'Initialize Boards & Channels
    Initialize_Boards
        
    'Initialize Waves
    Initialize_Waves
    
'----------------------------------------------------------------------------------------'
    'TEMPORARY CODE - Set globals
    AxialResFreq = 919.5
    TransResFreq = 324
    AxialMaxMonVoltage = 7.9
    AxialMaxRampVoltage = 2
    TransMaxMonVoltage = 3.9
    TransMaxRampVoltage = 2.5
    ReRampThreshold = 5
    NoiseLevel = 10 * (20 / 2 ^ 16)
'----------------------------------------------------------------------------------------'
    
    'Set all the TTL relays to the closed position
    optCoil_Click -1
    
    'Set Un-monitored /clipping test check-box to unchecked.
    '(Clipping test = unmonitored ramp cycle)
    Me.checkClippingTest.Value = Unchecked
   
    'Set Debug (AF Data save) mode to off
    Me.checkVerbose.Value = Unchecked
   
    'Just for now, store values that are testing in user controls so can test code faster
    If Me.optCoil(0).Value = True Then
    
        Me.txtFreq = "919.5"
        
    ElseIf Me.optCoil(1).Value = True Then
    
        Me.txtFreq = "324"
        
    Else
    
        Me.txtFreq = ""
        
    End If
    
    Me.txtRampUpDuration = "1000"
    Me.txtRampDownDuration = "1000"
    Me.txtRampRate = "50000"
    Me.txtRampPeakVoltage = "0.3"
    Me.txtMonitorTrigVolt = "1"
    Me.txtPeakField = ""
        
End Sub

Private Sub Form_Unload(Cancel As Integer)

    Dim i As Long
    Dim j As Long

    'Return Timer to normal ~15 ms accuracy
    timeEndPeriod 1
    
    'If the AFSystem is ADWIN, then open all the relays
    optCoil_Click -2

End Sub

Public Sub optCoil_Click(Index As Integer)
    
    Dim TTLBoard As Board
    Dim DataValue As Integer
    Dim ReturnVal As Long
    Dim i, N As Long
    Dim MemBuffer As Long
    Dim DataArray() As Double
    Dim TempArray() As Integer
    Dim Status As Integer
    Dim CurCount, CurIndex As Long
    
    Dim ReturnArray(16) As Long
        
    Dim CRange As Range
    Dim TempD As Double
    Dim TempI As Integer
    Dim Temp2_I As Integer
    
    Set TTLBoard = Nothing
    
    If AFSystem = "ADWIN" Then
    
        'Set the TTL Board = the ADWIN light board
        Set TTLBoard = DAQBoards("ADWIN-light-16")
        
        'Make sure only one coil is selected at a time
        If Index = 0 Then optCoil(1) = Not optCoil(0)
        If Index = 1 Then optCoil(0) = Not optCoil(1)
        
        If Index = -1 Then
        
            'This is the call to open all of the TTL relays
            TTLBoard.DigitalOut_ADWIN 0
            
            Me.txtFreq = ""
            
            Exit Sub
            
        End If
        
        If Index = -2 Then
        
            'This is the call to close all of the TTL relays
            'This switches the 5V power supply to the relays off
            'so that they don't over-heat
            TTLBoard.DigitalOut_ADWIN 63
                        
            Me.txtFreq = ""
            
            Exit Sub
            
        End If
             
        'If Axial coil is selected
        If optCoil(0).Value = True Then
        
            'Close the Axial relay, open all the other relays
            TTLBoard.DigitalOut AFAxialRelay.ChanNum, _
                                True, _
                                True
            
            CoilString = "Axial"
            Me.txtFreq = "919.5"
            
        ElseIf optCoil(1).Value = True Then
    
            'Close the Transverse relay, open all the other relays
            TTLBoard.DigitalOut AFTransRelay.ChanNum, _
                                True, _
                                True
            
            CoilString = "Transverse"
            Me.txtFreq = "324"
            
        End If
        
    End If
    
End Sub

Private Sub txtFreq_Change()

    If val(txtFreq) <> 0 Then
        Me.txtRampPeakDuration = Trim(Str(1 / val(txtFreq) * 100000))
    End If
    
End Sub



